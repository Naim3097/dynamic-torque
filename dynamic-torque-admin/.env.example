# WARNING: This file is bundled as a Flutter asset and shipped in the client.
# NEVER put service_role keys, Firebase server credentials, or other secrets here.
# Only publishable/anon keys belong in this file.

# Supabase (shared with dynamic-torque-web)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=

# Edge Function endpoint (derived from SUPABASE_URL automatically
# but can be overridden for local functions runtime)
SUPABASE_FUNCTIONS_URL=
